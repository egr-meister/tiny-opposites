{
  "expo": {
    "name": "Tiny Opposites",
    "slug": "tiny-opposites",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8EC"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFF8EC"
      },
      "package": "com.tinyopposites.app",
      "versionCode": 1,
      "edgeToEdgeEnabled": true,
      "permissions": []
    }
  }
}
